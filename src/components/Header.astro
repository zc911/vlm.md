---
interface Props {
  lang: 'zh' | 'en';
  currentPath?: string;
}

const { lang, currentPath = '' } = Astro.props;

const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherPath = currentPath
  ? currentPath.replace(/^\/(zh|en)(\/|$)/, `/${otherLang}$2`)
  : '';

const nav = {
  zh: { home: '首页', recipes: '食谱', about: '关于' },
  en: { home: 'Home', recipes: 'Recipes', about: 'About' },
}[lang];
---

<header class="border-b border-gray-800 sticky top-0 bg-gray-950/95 backdrop-blur z-50">
  <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={`/${lang}`} class="font-mono font-semibold text-lg text-white hover:text-violet-400 transition-colors">
      vlm<span class="text-violet-400">.md</span>
    </a>
    <nav class="flex items-center gap-6 text-sm">
      <a href={`/${lang}/recipes`} class="text-gray-400 hover:text-white transition-colors">{nav.recipes}</a>
      <a
        href={otherPath || `/${otherLang}`}
        class="px-2 py-1 rounded border border-gray-700 text-xs text-gray-400 hover:border-violet-500 hover:text-violet-400 transition-colors font-mono"
      >
        {otherLang === 'en' ? 'EN' : '中文'}
      </a>
    </nav>
  </div>
</header>
