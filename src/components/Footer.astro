---
interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;

const text = {
  zh: { contribute: '贡献食谱', builtWith: '用 Astro 构建，部署于 Cloudflare Pages' },
  en: { contribute: 'Contribute a Recipe', builtWith: 'Built with Astro, deployed on Cloudflare Pages' },
}[lang];
---

<footer class="border-t border-gray-800 mt-16">
  <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
    <span class="font-mono">vlm<span class="text-violet-400">.md</span></span>
    <a href={`https://github.com/vlm-md/vlm.md/blob/main/CONTRIBUTING${lang === 'zh' ? '.zh' : ''}.md`} class="hover:text-violet-400 transition-colors">
      {text.contribute}
    </a>
    <span>{text.builtWith}</span>
  </div>
</footer>
