---
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_LABELS } from '../content/config';

interface Props {
  recipe: CollectionEntry<'recipes'>;
  lang: 'zh' | 'en';
}

const { recipe, lang } = Astro.props;
const { title, description, category, models, difficulty, slug } = recipe.data;

const categoryLabel = CATEGORY_LABELS[category][lang];

const difficultyColor = {
  beginner: 'text-green-400 border-green-800',
  intermediate: 'text-yellow-400 border-yellow-800',
  advanced: 'text-red-400 border-red-800',
}[difficulty] ?? 'text-gray-400 border-gray-700';

const difficultyLabel = ({
  zh: { beginner: '入门', intermediate: '进阶', advanced: '高级' },
  en: { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' },
}[lang][difficulty]) ?? difficulty;
---

<a
  href={`/${lang}/recipes/${slug}`}
  class="block rounded-lg border border-gray-800 bg-gray-900 p-5 hover:border-violet-700 transition-all group"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <span class="text-xs px-2 py-0.5 rounded border border-gray-700 text-gray-400 font-mono">
      {categoryLabel}
    </span>
    <span class={`text-xs px-2 py-0.5 rounded border font-mono ${difficultyColor}`}>
      {difficultyLabel}
    </span>
  </div>
  <h3 class="font-semibold text-white group-hover:text-violet-300 transition-colors mb-2 leading-snug">
    {title}
  </h3>
  <p class="text-sm text-gray-400 line-clamp-2 mb-4">{description}</p>
  <div class="flex flex-wrap gap-1">
    {models.map((model) => (
      <span class="text-xs px-1.5 py-0.5 rounded bg-gray-800 text-gray-400 font-mono">
        {model}
      </span>
    ))}
  </div>
</a>
