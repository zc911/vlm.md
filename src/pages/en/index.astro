---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en' as const;
const recipes = await getCollection('recipes', (r) => r.data.lang === 'en');
const featured = recipes.slice(0, 3);

const categories = [
  { key: 'document-understanding', label: 'Document Understanding', icon: '📄' },
  { key: 'ui-grounding', label: 'UI Grounding', icon: '🖱️' },
  { key: 'chart-table', label: 'Chart & Table', icon: '📊' },
  { key: 'computer-use', label: 'Computer Use', icon: '💻' },
  { key: 'multi-image', label: 'Multi-image Reasoning', icon: '🖼️' },
  { key: 'structured-output', label: 'Structured Output', icon: '🗂️' },
];
---

<BaseLayout title="VLM Recipe Cookbook" lang={lang}>
  <Header slot="header" lang={lang} currentPath="/en/" />
  <Footer slot="footer" lang={lang} />

  <section class="py-16 text-center">
    <p class="text-violet-400 font-mono text-sm mb-4">vlm.md</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 leading-tight">
      VLM × Agent<br />
      <span class="text-violet-400">Recipe Cookbook</span>
    </h1>
    <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-8">
      Battle-tested recipes for using VLMs in agent systems. Which model, which prompt,
      working code, and the gotchas we hit in production.
    </p>
    <div class="flex gap-4 justify-center">
      <a href="/en/recipes" class="px-6 py-2.5 bg-violet-600 hover:bg-violet-500 text-white rounded-lg font-medium transition-colors">
        Browse Recipes
      </a>
      <a href="https://github.com/vlm-md/vlm.md/blob/main/CONTRIBUTING.md" class="px-6 py-2.5 border border-gray-700 hover:border-violet-500 text-gray-300 rounded-lg font-medium transition-colors">
        Contribute
      </a>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-lg font-semibold text-gray-300 mb-6">Browse by Category</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {categories.map((cat) => (
        <a
          href={`/en/recipes?category=${cat.key}`}
          class="flex items-center gap-3 p-4 rounded-lg border border-gray-800 bg-gray-900 hover:border-violet-700 transition-colors"
        >
          <span class="text-2xl">{cat.icon}</span>
          <span class="text-sm font-medium text-gray-300">{cat.label}</span>
        </a>
      ))}
    </div>
  </section>

  {featured.length > 0 && (
    <section>
      <h2 class="text-lg font-semibold text-gray-300 mb-6">Latest Recipes</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.map((recipe) => (
          <RecipeCard recipe={recipe} lang={lang} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
