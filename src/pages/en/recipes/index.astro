---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import RecipeCard from '../../../components/RecipeCard.astro';
import Search from '../../../components/Search.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../../../content/config';

const lang = 'en' as const;
const allRecipes = await getCollection('recipes', (r) => r.data.lang === 'en');
const sorted = allRecipes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = Object.entries(CATEGORY_LABELS).map(([key, labels]) => ({
  key,
  label: labels.en,
}));
---

<BaseLayout title="All Recipes" lang={lang}>
  <Header slot="header" lang={lang} currentPath="/en/recipes" />
  <Footer slot="footer" lang={lang} />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white mb-2">All Recipes</h1>
    <p class="text-gray-400">{sorted.length} recipes</p>
  </div>

  <div class="mt-4 mb-6">
    <Search lang={lang} />
  </div>

  <div class="flex gap-2 flex-wrap mb-8" id="category-filters">
    <button
      data-category="all"
      class="category-btn px-3 py-1.5 rounded-lg text-sm border border-violet-500 text-violet-400 font-mono"
    >
      All
    </button>
    {categories.map((cat) => (
      <button
        data-category={cat.key}
        class="category-btn px-3 py-1.5 rounded-lg text-sm border border-gray-700 text-gray-400 font-mono hover:border-violet-500 hover:text-violet-400 transition-colors"
      >
        {cat.label}
      </button>
    ))}
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="recipe-grid">
    {sorted.map((recipe) => (
      <div data-category={recipe.data.category} class="recipe-item">
        <RecipeCard recipe={recipe} lang={lang} />
      </div>
    ))}
  </div>
</BaseLayout>

<script>
  const filterContainer = document.getElementById('category-filters')!;
  const grid = document.getElementById('recipe-grid')!;
  const buttons = filterContainer.querySelectorAll<HTMLButtonElement>('.category-btn');
  const items = grid.querySelectorAll<HTMLElement>('.recipe-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category!;
      buttons.forEach((b) => b.classList.remove('border-violet-500', 'text-violet-400'));
      btn.classList.add('border-violet-500', 'text-violet-400');
      items.forEach((item) => {
        const show = selected === 'all' || item.dataset.category === selected;
        item.style.display = show ? '' : 'none';
      });
    });
  });

  const initial = new URLSearchParams(location.search).get('category');
  if (initial) {
    const target = document.querySelector<HTMLButtonElement>(
      `.category-btn[data-category="${CSS.escape(initial)}"]`
    );
    target?.click();
  }
</script>
